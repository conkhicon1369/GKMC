<%- include('../partials/header', { title: room.roomType }) %>

<div class="section">
  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/">Trang chủ</a> › 
    <strong><%= room.roomType %></strong> — 
    <%= room.hotelId ? room.hotelId.name + ', ' + room.hotelId.city : '' %>
  </div>

  <div class="detail-layout">
    <!-- CỘT TRÁI: Ảnh + Thông tin -->
    <div>
      <div class="detail-main-img">🛏</div>

      <div style="margin-top: 1.5rem;">
        <h2 style="font-size:1.1rem; font-weight:700; margin-bottom:1rem; color: var(--primary);">Thông Tin Phòng</h2>
        <p style="color: var(--text-muted); font-size:0.9rem; line-height:1.7; margin-bottom:1.25rem;">
          <%= room.description || 'Phòng tiện nghi, thoáng mát, được trang bị đầy đủ tiện ích hiện đại.' %>
        </p>

        <% if (room.amenities && room.amenities.length > 0) { %>
          <h3 style="font-size:1rem; font-weight:700; margin-bottom:0.75rem;">Tiện Nghi</h3>
          <div class="amenities-list">
            <% room.amenities.forEach(a => { %>
              <span class="amenity-tag">✓ <%= a %></span>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- ĐÁNH GIÁ -->
      <% if (reviews && reviews.length > 0) { %>
        <div class="reviews">
          <h3 style="font-size:1rem; font-weight:700; margin-bottom:1rem;">Đánh Giá Khách Hàng</h3>
          <% reviews.forEach(r => { %>
            <div class="review-item">
              <div class="review-header">
                <span class="review-author"><%= r.userId ? r.userId.fullName : 'Khách' %></span>
                <span class="review-date"><%= r.createdAt.toLocaleDateString('vi-VN') %></span>
              </div>
              <div class="stars">
                <% for(let i=0; i<r.rating; i++) { %>★<% } %>
                <% for(let i=r.rating; i<5; i++) { %>☆<% } %>
              </div>
              <p class="review-comment"><%= r.comment %></p>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- CỘT PHẢI: Card đặt phòng -->
    <div>
      <div class="booking-summary" style="position: sticky; top: 75px;">
        <h2 style="font-size:1.2rem; font-weight:700; margin-bottom:0.25rem;"><%= room.roomType %></h2>
        <p style="color: var(--text-muted); font-size:0.85rem; margin-bottom:1rem;">
          <%= room.hotelId ? room.hotelId.name : '' %>
        </p>

        <ul class="detail-meta">
          <li>
            <span class="meta-label">Loại phòng</span>
            <span><%= room.roomType %></span>
          </li>
          <% if (room.hotelId) { %>
          <li>
            <span class="meta-label">Khách sạn</span>
            <span><%= room.hotelId.name %></span>
          </li>
          <li>
            <span class="meta-label">Thành phố</span>
            <span><%= room.hotelId.city %></span>
          </li>
          <% } %>
          <li>
            <span class="meta-label">Sức chứa</span>
            <span>👥 <%= room.capacity %> người</span>
          </li>
          <li>
            <span class="meta-label">Diện tích</span>
            <span>📐 <%= room.size %>m²</span>
          </li>
          <li>
            <span class="meta-label">Số phòng trống</span>
            <span>🚪 <%= room.availableRooms %> / <%= room.quantity %></span>
          </li>
        </ul>

        <% if (room.availableRooms > 0) { %>
          <div class="available-badge">✓ Còn <%= room.availableRooms %> phòng trống</div>
        <% } else { %>
          <div class="available-badge" style="background:#f8d7da; color:#721c24;">✗ Hết phòng</div>
        <% } %>

        <div class="price-big">
          <%= room.pricePerNight.toLocaleString('vi-VN') %>₫
          <span>/ đêm</span>
        </div>

        <% if (room.availableRooms > 0) { %>
          <a href="/bookings/new/<%= room._id %>" class="btn btn-primary btn-full" style="margin-bottom:0.5rem;">
            Đặt Phòng Ngay
          </a>
          <p style="font-size:0.78rem; color:var(--text-muted); text-align:center;">🔒 Miễn phí hủy trước 24h</p>
        <% } else { %>
          <button class="btn btn-full" disabled style="background:#ddd; color:#999; cursor:not-allowed;">Hết Phòng</button>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
