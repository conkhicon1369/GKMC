<%- include('../partials/header', { title: 'Đặt Phòng' }) %>

<div class="section">
  <div class="breadcrumb">
    <a href="/">Trang chủ</a> ›
    <a href="/rooms/<%= room._id %>"><%= room.roomType %></a> ›
    <strong>Đặt Phòng</strong>
  </div>

  <h2 style="font-size:1.3rem; font-weight:700; margin-bottom:1.5rem;">Đặt Phòng</h2>

  <div class="booking-layout">
    <!-- FORM ĐẶT PHÒNG -->
    <div>
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius:6px; padding:1.5rem;">
        <form action="/bookings" method="POST">
          <input type="hidden" name="roomId" value="<%= room._id %>">

          <div class="form-group">
            <label>Tên của bạn <span style="color:var(--danger)">*</span></label>
            <input type="text" name="guestName" class="form-control" 
              placeholder="Nguyễn Văn A"
              value="<%= currentUser ? currentUser.fullName : '' %>" required>
          </div>

          <div class="form-group">
            <label>Số điện thoại <span style="color:var(--danger)">*</span></label>
            <input type="tel" name="guestPhone" class="form-control" 
              placeholder="0123456789" required>
          </div>

          <div class="form-group">
            <label>Email <span style="color:var(--danger)">*</span></label>
            <input type="email" name="guestEmail" class="form-control" 
              placeholder="email@gmail.com"
              value="<%= currentUser ? currentUser.email : '' %>" required>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>Ngày nhận phòng <span style="color:var(--danger)">*</span></label>
              <input type="date" name="checkInDate" class="form-control" 
                min="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            <div class="form-group">
              <label>Ngày trả phòng <span style="color:var(--danger)">*</span></label>
              <input type="date" name="checkOutDate" class="form-control" required>
            </div>
          </div>

          <div class="form-group">
            <label>Số lượng phòng <span style="color:var(--danger)">*</span></label>
            <select name="roomCount" class="form-control" id="roomCount" onchange="updateTotal()">
              <% for(let i = 1; i <= room.availableRooms; i++) { %>
                <option value="<%= i %>"><%= i %> phòng</option>
              <% } %>
            </select>
          </div>

          <button type="submit" class="btn btn-primary btn-full" style="margin-top:0.5rem; padding:0.75rem;">
            Xác Nhận Đặt Phòng
          </button>
          <p style="text-align:center; font-size:0.78rem; color:var(--text-muted); margin-top:0.5rem;">
            🔒 Thông tin của bạn được bảo mật
          </p>
        </form>
      </div>
    </div>

    <!-- BOOKING SUMMARY -->
    <div class="booking-summary">
      <h3>Thông Tin Phòng</h3>
      <div class="summary-room-img">🛏</div>

      <p style="font-weight:600; margin-bottom:0.25rem;"><%= room.roomType %></p>
      <p style="font-size:0.82rem; color:var(--text-muted); margin-bottom:1rem;">
        <%= room.hotelId ? room.hotelId.name + ', ' + room.hotelId.city : '' %>
      </p>

      <div class="summary-row">
        <span>Loại phòng</span>
        <span><%= room.roomType %></span>
      </div>
      <div class="summary-row">
        <span>Sức chứa</span>
        <span><%= room.capacity %> người</span>
      </div>
      <div class="summary-row">
        <span>Giá / đêm</span>
        <span><%= room.pricePerNight.toLocaleString('vi-VN') %>₫</span>
      </div>
      <div class="summary-row">
        <span>Số phòng</span>
        <span id="summaryCount">1</span>
      </div>

      <div class="summary-total">
        <span>Tổng cộng:</span>
        <span id="summaryTotal"><%= room.pricePerNight.toLocaleString('vi-VN') %>₫</span>
      </div>

      <p style="font-size:0.78rem; color:var(--success); margin-top:0.75rem;">✓ Miễn phí hủy trước 24h</p>
    </div>
  </div>
</div>

<script>
  const pricePerNight = <%= room.pricePerNight %>;

  function updateTotal() {
    const count = parseInt(document.getElementById('roomCount').value);
    document.getElementById('summaryCount').textContent = count + ' phòng';
    const total = pricePerNight * count;
    document.getElementById('summaryTotal').textContent = total.toLocaleString('vi-VN') + '₫';
  }

  // Validate ngày
  document.querySelector('[name="checkInDate"]').addEventListener('change', function() {
    document.querySelector('[name="checkOutDate"]').min = this.value;
  });
</script>

<%- include('../partials/footer') %>
