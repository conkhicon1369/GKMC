<%- include('../partials/header', { title: 'Đăng Nhập' }) %>

<div class="section">
  <div class="auth-box">
    <h2>Đăng Nhập</h2>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" class="form-control" placeholder="email@gmail.com" required>
      </div>
      <div class="form-group">
        <label>Mật khẩu</label>
        <input type="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full" style="padding:0.7rem; margin-top:0.25rem;">
        Đăng Nhập
      </button>
    </form>

    <p style="text-align:center; margin-top:1rem; font-size:0.88rem; color:var(--text-muted);">
      Chưa có tài khoản? <a href="/auth/register">Đăng ký ngay</a>
    </p>

    <div style="margin-top:1.25rem; padding:0.75rem; background:var(--bg); border-radius:4px; font-size:0.8rem; color:var(--text-muted);">
      <strong>Tài khoản admin demo:</strong><br>
      Email: <code>admin@hotel.com</code> | Pass: <code>admin123</code>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
