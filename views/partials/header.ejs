<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>Khách Sạn Booking</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">🏨 HotelBooking</a>
  <ul class="navbar-nav">
    <li><a href="/">Trang Chủ</a></li>
    <% if (currentUser) { %>
      <% if (currentUser.role === 'admin') { %>
        <li><a href="/admin">Quản Trị</a></li>
      <% } %>
      <li><a href="/auth/logout">Đăng Xuất (<%= currentUser.fullName %>)</a></li>
    <% } else { %>
      <li><a href="/auth/login">Đăng Nhập</a></li>
      <li><a href="/auth/register">Đăng Ký</a></li>
    <% } %>
  </ul>
</nav>

<% if (success && success.length > 0) { %>
  <div class="flash-container">
    <% success.forEach(msg => { %>
      <div class="flash-success">✓ <%= msg %></div>
    <% }) %>
  </div>
<% } %>
<% if (error && error.length > 0) { %>
  <div class="flash-container">
    <% error.forEach(msg => { %>
      <div class="flash-error">⚠ <%= msg %></div>
    <% }) %>
  </div>
<% } %>
