<%- include('partials/header', { title: 'Trang Chủ' }) %>

<!-- HERO + SEARCH (Yêu cầu 3) -->
<div class="hero">
  <h1>Tìm Phòng Khách Sạn Phù Hợp</h1>
  <p>Đặt phòng nhanh chóng, tiện lợi và an toàn</p>

  <form action="/" method="GET" class="search-box">
    <div class="form-group">
      <label>Địa điểm</label>
      <input type="text" name="city" placeholder="Nhập thành phố..." value="<%= city || '' %>">
    </div>
    <div class="form-group">
      <label>Ngày nhận phòng</label>
      <input type="date" name="checkIn" value="<%= checkIn || '' %>">
    </div>
    <div class="form-group">
      <label>Ngày trả phòng</label>
      <input type="date" name="checkOut" value="<%= checkOut || '' %>">
    </div>
    <div class="form-group" style="flex:0">
      <button type="submit" class="btn btn-accent" style="white-space:nowrap">🔍 Tìm Kiếm</button>
    </div>
  </form>
</div>

<!-- DANH SÁCH PHÒNG (Yêu cầu 1) -->
<div class="section">
  <div>
    <h2 class="section-title">Phòng Nổi Bật</h2>
    <p class="section-sub">
      <% if (checkIn && checkOut) { %>
        Kết quả tìm phòng trống từ <strong><%= checkIn %></strong> đến <strong><%= checkOut %></strong>
        — Tìm thấy <%= rooms.length %> phòng
      <% } else { %>
        Những phòng khách sạn tốt nhất dành cho bạn
      <% } %>
    </p>
  </div>

  <% if (rooms.length === 0) { %>
    <div class="no-result">
      <p>😔 Không tìm thấy phòng phù hợp</p>
      <a href="/" class="btn btn-outline" style="margin-top:1rem">Xem tất cả phòng</a>
    </div>
  <% } else { %>
    <div class="rooms-grid">
      <% rooms.forEach(room => { %>
        <div class="room-card">
          <div class="room-card-img">🛏</div>
          <div class="room-card-body">
            <div class="room-card-title"><%= room.roomType %></div>
            <div class="room-card-hotel">
              📍 <%= room.hotelId ? room.hotelId.name + ', ' + room.hotelId.city : 'N/A' %>
            </div>
            <div class="room-card-meta">
              <span>👥 <%= room.capacity %> người</span>
              <span>📐 <%= room.size %>m²</span>
              <span>🚪 Còn <%= room.availableRooms %> phòng</span>
            </div>
            <div class="room-card-price">
              <%= room.pricePerNight.toLocaleString('vi-VN') %>₫
              <span>/ đêm</span>
            </div>
            <a href="/rooms/<%= room._id %>" class="btn btn-primary btn-full">Xem Chi Tiết</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
