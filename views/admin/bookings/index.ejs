<%- include('../../../partials/header', { title: 'Danh Sách Đặt Phòng' }) %>

<div class="admin-layout">
  <div class="admin-sidebar">
    <a href="/admin">📊 Dashboard</a>
    <a href="/admin/rooms">🚪 Quản lý Phòng</a>
    <a href="/admin/bookings" class="active">📋 Đặt Phòng</a>
    <a href="/">← Trang Chủ</a>
  </div>

  <div class="admin-content">
    <h2 style="font-size:1.2rem; font-weight:700; color:var(--primary); margin-bottom:1.5rem;">
      Danh Sách Khách Hàng Đặt Phòng
    </h2>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Khách Hàng</th>
            <th>Liên Hệ</th>
            <th>Phòng</th>
            <th>Nhận Phòng</th>
            <th>Trả Phòng</th>
            <th>Số Phòng</th>
            <th>Tổng Tiền</th>
            <th>Trạng Thái</th>
            <th>TT Thanh Toán</th>
            <th>Hành Động</th>
          </tr>
        </thead>
        <tbody>
          <% if (bookings.length === 0) { %>
            <tr>
              <td colspan="11" style="text-align:center; color:var(--text-muted); padding:2rem;">
                Chưa có đặt phòng nào
              </td>
            </tr>
          <% } %>
          <% bookings.forEach((b, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td style="font-weight:600;"><%= b.guestName %></td>
              <td style="font-size:0.8rem; color:var(--text-muted);">
                <%= b.guestPhone %><br><%= b.guestEmail %>
              </td>
              <td style="font-size:0.85rem;">
                <%= b.roomId ? b.roomId.roomType : 'N/A' %>
              </td>
              <td style="font-size:0.85rem;">
                <%= new Date(b.checkInDate).toLocaleDateString('vi-VN') %>
              </td>
              <td style="font-size:0.85rem;">
                <%= new Date(b.checkOutDate).toLocaleDateString('vi-VN') %>
              </td>
              <td style="text-align:center;"><%= b.roomCount %></td>
              <td style="font-weight:600; color:var(--primary); white-space:nowrap;">
                <%= b.totalPrice.toLocaleString('vi-VN') %>₫
              </td>
              <td>
                <span class="badge badge-<%= b.status %>">
                  <% if(b.status === 'pending') { %>Chờ xác nhận
                  <% } else if(b.status === 'confirmed') { %>Đã xác nhận
                  <% } else { %>Đã hủy<% } %>
                </span>
              </td>
              <td>
                <span class="badge badge-<%= b.paymentStatus %>">
                  <%= b.paymentStatus === 'paid' ? 'Đã thanh toán' : 'Chưa thanh toán' %>
                </span>
              </td>
              <td>
                <form action="/admin/bookings/<%= b._id %>/status?_method=PUT" method="POST" style="display:flex; gap:0.35rem;">
                  <select name="status" class="form-control" style="padding:0.25rem; font-size:0.78rem; width:auto;">
                    <option value="pending"   <%= b.status==='pending'    ? 'selected':'' %>>Chờ</option>
                    <option value="confirmed" <%= b.status==='confirmed'  ? 'selected':'' %>>Xác nhận</option>
                    <option value="cancelled" <%= b.status==='cancelled'  ? 'selected':'' %>>Hủy</option>
                  </select>
                  <button type="submit" class="btn btn-success btn-sm">✓</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../../../partials/footer') %>
